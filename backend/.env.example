# Signal Sports — backend environment variables
# Copy to backend/.env and fill in values.
# Never commit backend/.env to git.

# ---------------------------------------------------------------------------
# Translation provider
# ---------------------------------------------------------------------------
# Options:
#   disabled  (default) — translation is off; articles keep their original title
#   fake               — dev-only stub; returns realistic Hebrew for known titles,
#                        "תרגום בדיקה: <original>" for unknown ones. No API key needed.
#   claude             — uses the Anthropic Claude API (requires TRANSLATION_API_KEY)
# ---------------------------------------------------------------------------
TRANSLATION_PROVIDER=claude

# Required when TRANSLATION_PROVIDER=claude
TRANSLATION_API_KEY=sk-ant-your-key-here

# Claude model to use for translation (default shown below)
TRANSLATION_MODEL=claude-haiku-4-5-20251001

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# SQLite path relative to backend/
DATABASE_URL=sqlite:///./data/signal_sports.db
