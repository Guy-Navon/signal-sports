# Signal Sports backend configuration
# Copy to .env and edit as needed. Values shown here are the defaults.

# Database
DATABASE_URL=sqlite:///./data/signal_sports.db

# Translation
TRANSLATION_PROVIDER=disabled
TRANSLATION_API_KEY=
TRANSLATION_MODEL=claude-haiku-4-5-20251001

# LLM Classification (Hebrew broad sources: walla_sport, israel_hayom_sport)
#
# Options:
#   disabled  — no LLM, deterministic rules only (default, zero config)
#   gemini    — Google Gemini API (recommended: free tier, fast, cloud)
#   ollama    — local Ollama instance (fully local, no API key, slower on CPU)
#   fake      — dev mode: returns pre-set results for known test headlines
#
CLASSIFICATION_PROVIDER=disabled

# Model to use (default shown per provider):
#   gemini:  gemini-2.5-flash-lite
#   ollama:  llama3.2:3b
CLASSIFICATION_MODEL=gemini-2.5-flash-lite

# Required when CLASSIFICATION_PROVIDER=gemini
# Get a free key at Google AI Studio (aistudio.google.com)
CLASSIFICATION_API_KEY=

# Used when CLASSIFICATION_PROVIDER=ollama
CLASSIFICATION_OLLAMA_BASE_URL=http://localhost:11434
CLASSIFICATION_TIMEOUT_SECONDS=15

# Selective LLM gating — skip LLM when the deterministic result is already strong.
# Evaluated once at backend startup; changing this value requires a restart.
#
#   enabled  — skip LLM for articles where sport/league/entity/event are already clear
#              (default; recommended for production; targets ≥40% fewer LLM calls)
#   disabled — always call LLM for eligible articles; reproduces pre-gating behaviour
#              (use for benchmarking or debugging classification regressions)
#
CLASSIFICATION_LLM_GATING=enabled

# Dev-only: enables POST /api/dev/reset-rss-data
# Set to true only for local QA / benchmark sessions. Never enable in production.
ALLOW_DEV_RESET=false

# ── CORPUS SAFETY (issue #106) ────────────────────────────────────────────────
# The real article corpus (data/signal_sports.db) is NOT in git and CANNOT be
# restored. On 2026-07-12 it was wiped from 404 RSS articles to 0 because
# ALLOW_DEV_RESET=true was set while DATABASE_URL pointed at the corpus.
#
# Destructive dev routes now guard the TARGET DATABASE, not just the flag above:
#
#   POST /api/dev/benchmark/llm-gating
#     Resets RSS data TWICE per run by design. It is HARD-REFUSED (409) whenever
#     DATABASE_URL resolves to data/signal_sports.db. There is NO override.
#     Run it against a copy instead:
#         cp data/signal_sports.db data/benchmark_copy.db
#         DATABASE_URL=sqlite:///./data/benchmark_copy.db
#
#   POST /api/dev/reset-rss-data
#     Against the corpus it requires a SECOND, corpus-specific opt-in below,
#     on top of ALLOW_DEV_RESET. One boolean is not authority to destroy the corpus.
#
# Leave this false. Set it only to intentionally destroy the real corpus.
ALLOW_CORPUS_DB_RESET=false

# Auth Core (User Platform PR 1)
# Secure must be set explicitly because Tailscale Serve terminates HTTPS before
# the Vite proxy / uvicorn chain, so FastAPI cannot infer browser scheme.
AUTH_COOKIE_SECURE=false
AUTH_ADMIN_EMAIL=
AUTH_ADMIN_PASSWORD=
ALLOW_INSECURE_AUTH_BYPASS=false
CSRF_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175

# ── Story clustering (Milestone 5, issue #101) ────────────────────────────────
# Groups cross-source articles reporting the SAME real-world story into one feed card.
# Deterministic; no LLM. See docs/CLUSTERING.md.
#
# DISABLED BY DEFAULT. The live scheduler must not cluster the real corpus until the
# Checkpoint-2 QA gate (#102) has passed on a frozen COPY of the corpus. Clustering is a
# quality-enhancement stage: if it fails it leaves articles inserted but UNCLUSTERED and
# reports the failure on the ingest run — it never corrupts ingestion, and it never
# touches URL dedup or article facts.
CLUSTERING_ENABLED=false
