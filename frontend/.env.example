# Signal Sports frontend configuration
# Copy to .env.local and edit as needed.

# Data mode
# local   — uses mock articles + frontend JS engine; no backend required (default)
# backend — fetches from FastAPI; backend scores articles; frontend renders only
VITE_DATA_MODE=backend

# Backend URL override — leave unset for same-origin requests via the Vite
# dev proxy (server.proxy in vite.config.js forwards /api and /health to
# http://127.0.0.1:8000). This is required for phone/remote access.
# Set only to bypass the proxy and call a backend directly, cross-origin:
# VITE_API_BASE_URL=http://127.0.0.1:8000
