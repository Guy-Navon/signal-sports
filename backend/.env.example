# Signal Sports backend configuration
# Copy to .env and edit as needed. Values shown here are the defaults.

# Database
DATABASE_URL=sqlite:///./data/signal_sports.db

# Translation
TRANSLATION_PROVIDER=disabled
TRANSLATION_API_KEY=
TRANSLATION_MODEL=claude-haiku-4-5-20251001

# LLM Classification (Hebrew broad sources: walla_sport, israel_hayom_sport)
#
# Options:
#   disabled  — no LLM, deterministic rules only (default, zero config)
#   gemini    — Google Gemini API (recommended: free tier, fast, cloud)
#   ollama    — local Ollama instance (fully local, no API key, slower on CPU)
#   fake      — dev mode: returns pre-set results for known test headlines
#
CLASSIFICATION_PROVIDER=disabled

# Model to use (default shown per provider):
#   gemini:  gemini-2.5-flash-lite
#   ollama:  llama3.2:3b
CLASSIFICATION_MODEL=gemini-2.5-flash-lite

# Required when CLASSIFICATION_PROVIDER=gemini
# Get a free key at Google AI Studio (aistudio.google.com)
CLASSIFICATION_API_KEY=

# Used when CLASSIFICATION_PROVIDER=ollama
CLASSIFICATION_OLLAMA_BASE_URL=http://localhost:11434
CLASSIFICATION_TIMEOUT_SECONDS=15

# Selective LLM gating — skip LLM when the deterministic result is already strong.
# Evaluated once at backend startup; changing this value requires a restart.
#
#   enabled  — skip LLM for articles where sport/league/entity/event are already clear
#              (default; recommended for production; targets ≥40% fewer LLM calls)
#   disabled — always call LLM for eligible articles; reproduces pre-gating behaviour
#              (use for benchmarking or debugging classification regressions)
#
CLASSIFICATION_LLM_GATING=enabled

# Dev-only: enables POST /api/dev/reset-rss-data
# Set to true only for local QA / benchmark sessions. Never enable in production.
ALLOW_DEV_RESET=false

# ── CORPUS SAFETY (issue #106) ────────────────────────────────────────────────
# The real article corpus (data/signal_sports.db) is NOT in git and CANNOT be
# restored. On 2026-07-12 it was wiped from 404 RSS articles to 0 because
# ALLOW_DEV_RESET=true was set while DATABASE_URL pointed at the corpus.
#
# Destructive dev routes now guard the TARGET DATABASE, not just the flag above:
#
#   POST /api/dev/benchmark/llm-gating
#     Resets RSS data TWICE per run by design. It is HARD-REFUSED (409) whenever
#     DATABASE_URL resolves to data/signal_sports.db. There is NO override.
#     Run it against a copy instead:
#         cp data/signal_sports.db data/benchmark_copy.db
#         DATABASE_URL=sqlite:///./data/benchmark_copy.db
#
#   POST /api/dev/reset-rss-data
#     Against the corpus it requires a SECOND, corpus-specific opt-in below,
#     on top of ALLOW_DEV_RESET. One boolean is not authority to destroy the corpus.
#
# Leave this false. Set it only to intentionally destroy the real corpus.
ALLOW_CORPUS_DB_RESET=false

# Auth Core (User Platform PR 1)
# Secure must be set explicitly because Tailscale Serve terminates HTTPS before
# the Vite proxy / uvicorn chain, so FastAPI cannot infer browser scheme.
AUTH_COOKIE_SECURE=false
AUTH_ADMIN_EMAIL=
AUTH_ADMIN_PASSWORD=
ALLOW_INSECURE_AUTH_BYPASS=false
CSRF_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:5175

# ── Story clustering (Milestone 5 #101; ACTIVATED by Milestone 6 #126) ────────
# Groups cross-source articles reporting the SAME real-world story into one feed card.
# Deterministic; no LLM. See docs/CLUSTERING.md.
#
# ACTIVE IN PRODUCTION since 2026-07-15 (#126) — the ranked feed shows each story
# once and pushes each story at most once. Clustering remains a quality-enhancement
# stage: if it fails it leaves articles inserted but UNCLUSTERED and reports the
# failure on the ingest run — it never corrupts ingestion, never touches URL dedup
# or article facts.
CLUSTERING_ENABLED=true

# ── Scheduled ingestion worker (Milestone 7, M7-2 #148) ───────────────────────
# The DEDICATED worker process (`python -m app.worker`) polls all enabled sources
# through the same orchestration + durable single-flight guard as manual runs.
# The API process runs NO scheduler — see docs/SCHEDULER.md.
#
# ACTIVATED IN PRODUCTION 2026-07-18 by the M7-10 gate (#156): the production
# .env runs SCHEDULER_ENABLED=true. The EXAMPLE default below stays false so a
# fresh checkout never starts polling by accident; flip it deliberately.
SCHEDULER_ENABLED=false
# Polling cadence (~5 minutes). One shared cadence; per-source enablement is the
# existing Sources-page toggle / source_overrides table.
SCHEDULER_INTERVAL_SECONDS=300
# Force one cycle at worker start regardless of staleness (normally false).
SCHEDULER_RUN_ON_STARTUP=false
# Run ONE catch-up cycle at worker start when the last successful cycle is older
# than one interval. Missed ticks are never replayed one-by-one.
SCHEDULER_STARTUP_CATCHUP=true
# A cycle exceeding this is flagged in health; it is NOT killed mid-transaction.
SCHEDULER_MAX_RUN_SECONDS=900
# A held single-flight lease whose heartbeat is older than this is considered
# dead and taken over (the abandoned cycle is marked as such).
SCHEDULER_STALE_AFTER_SECONDS=1800

# ── Feed freshness window (Milestone 8, #170-#175) ────────────────────────────
# The consumer feed is a CURRENT news feed: articles whose normalized source
# publication time (articles.published_at, UTC) is older than the window are
# excluded from ranked feeds and can never become Telegram PUSH notifications.
# One shared predicate (app/services/freshness.py) applied in build_feed —
# feed, cluster canonical selection and the notification planner all inherit
# it; no layer has its own age rule. Visibility only: nothing is deleted, and
# the Debug feed keeps showing everything. See docs/FEED_FRESHNESS.md.
#
# ACTIVATED IN PRODUCTION 2026-07-18 by the M8-5 gate (#175): the production
# .env runs FEED_FRESHNESS_ENABLED=true. The EXAMPLE default stays false —
# same activation pattern as CLUSTERING_ENABLED. Rollback: flip to false and
# restart the API + worker.
FEED_FRESHNESS_ENABLED=false
# The window in hours. Guarded parse: non-numeric or < 1 falls back to 36.
FEED_MAX_AGE_HOURS=36

# ── Article retention cleanup (Milestone 7, M7-3 #149) ────────────────────────
# Deletes rss_ articles older than the window, PROTECTING: clusters with any
# in-window member, feedback-referenced articles. Notification lineage survives
# by design (no FK). Runs as the LAST orchestration stage, after notification
# planning. Feed visibility != physical deletion (docs/CLUSTERING.md section 14):
# the window is weeks, not the 36h feed horizon, because URL dedup must remember
# purged URLs longer than any realistic republish horizon.
RETENTION_CLEANUP_ENABLED=false
ARTICLE_RETENTION_DAYS=30

# ── Telegram push pilot (Milestone 7, M7-5..M7-7 #151-#153) ───────────────────
# One bot, one private destination (Guy), PUSH-tier stories only, at most one
# message per stable story. See docs/NOTIFICATIONS.md for the full contract and
# the one-time BotFather/chat-id setup.
#
# ACTIVATED IN PRODUCTION 2026-07-18 by the M7-10 gate (#156): the production
# .env runs TELEGRAM_NOTIFICATIONS_ENABLED=true after the guarded watermark
# initialization (scripts/init_notification_watermark.py) suppressed the 7
# historical PUSH stories. The EXAMPLE default stays false: enabling without a
# watermark is fail-closed (the planner refuses to plan), and a fresh checkout
# must never be able to message anyone by accident.
TELEGRAM_NOTIFICATIONS_ENABLED=false
# The bot token from BotFather. SECRET — lives only in the untracked .env.
TELEGRAM_BOT_TOKEN=
# Guy's private chat id, resolved once via scripts/resolve_telegram_chat_id.py
# after messaging the bot. Treated as a secret (never logged or returned).
TELEGRAM_CHAT_ID=
# Production runs 20 (M7-10): transient 15-60s hangs to api.telegram.org were
# observed during Phase C; with a 10s timeout such a hang becomes an `unknown`
# outcome (never auto-resent), i.e. a possibly missed notification.
TELEGRAM_REQUEST_TIMEOUT_SECONDS=10
# Bounded retry for DEFINITE failures only (unknown outcomes are never retried).
TELEGRAM_MAX_ATTEMPTS=5
TELEGRAM_RETRY_BACKOFF_SECONDS=60
# Bumping the policy version deliberately opens a NEW notification identity
# space (requires its own guarded watermark initialization).
TELEGRAM_NOTIFICATION_POLICY_VERSION=v1
# The pilot profile. Guy-only by milestone contract.
TELEGRAM_NOTIFICATION_PROFILE=guy

# ── Personalized results (issue #178) ─────────────────────────────────────────
# A preference-filtered history of real game results (NBA / EuroLeague / EuroCup
# / Israeli Basketball Premier League / Spanish ACB). Relevance derives from the
# same ProfileV2 follows as the feed — the read path only reads the DB. See
# docs/RESULTS.md.
#
# Read surface (GET /api/me/results, /api/results/{user_id}) is always on when
# RESULTS_ENABLED=true — it is safe with an empty corpus.
RESULTS_ENABLED=true
# Provider abstraction. "thesportsdb" uses TheSportsDB's free public test key
# ("3" — documented, NOT a secret); "fake" is the offline/test provider.
RESULTS_PROVIDER=thesportsdb
THESPORTSDB_API_KEY=3
THESPORTSDB_BASE_URL=https://www.thesportsdb.com/api/v1/json
RESULTS_HTTP_TIMEOUT_SECONDS=15
RESULTS_HTTP_MAX_RETRIES=2
# Which competitions to sync (comp:* taxonomy ids), across sports. Only providers
# that know a league map it; others are skipped with a recorded error. Basketball:
# nba,euroleague,eurocup,ibl,acb. Football: ligat_haal,epl,la_liga,bundesliga,ucl.
RESULTS_COMPETITIONS=comp:nba,comp:euroleague,comp:eurocup,comp:ibl,comp:acb,comp:ligat_haal,comp:epl,comp:la_liga,comp:bundesliga,comp:ucl
# Seasons to fetch (blank = the two most recent, computed). Bounded on purpose.
RESULTS_SEASONS=
# How far back the read path shows games (bounded recent history, not the 36h
# feed horizon — results are a history, not a live feed).
RESULTS_WINDOW_DAYS=400
# The scheduler results-sync STAGE. Network activity is an ops opt-in, like
# CLUSTERING/TELEGRAM: the production .env runs RESULTS_SYNC_ENABLED=true; the
# EXAMPLE default stays false. The read path never needs it — a manual admin
# POST /api/results/sync (or the scheduler when enabled) populates the corpus.
RESULTS_SYNC_ENABLED=false
# Throttle: the scheduler stage skips if the last attempt is newer than this
# (opening the page never triggers a provider call; manual sync bypasses it).
RESULTS_SYNC_MIN_INTERVAL_SECONDS=1800
RESULTS_MAX_GAMES_PER_COMPETITION=80
